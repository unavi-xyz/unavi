package wired:prelude;

world lib-shared {
  include wired:math/prelude;
  include wired:scene/prelude;
  import wired:input/api;
  import wired:input/types;
}

world lib {
  import wired:agent/types;
  include lib-shared;
}

world lib-system {
  include lib-shared;
  include wired:agent/prelude;
  import wired:input/system-api;
}

world script {
  include lib;
  include wired:script/guest;
}

world script-system {
  include lib-system;
  include wired:script/guest;
}
